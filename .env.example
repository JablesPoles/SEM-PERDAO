# Supabase — necessário para o modo online (salas multiplayer).
# Crie um projeto gratuito em https://supabase.com (ou reuse o do FDP),
# copie estes valores de Settings > API e cole em .env.local (não comitado).
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
