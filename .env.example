# Supabase — necessário para o modo online (salas multiplayer).
# Crie um projeto gratuito em https://supabase.com (ou reuse o do FDP),
# copie estes valores de Settings > API e cole em .env.local (não comitado).
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# ElevenLabs — SÓ pra gerar os áudios (npm run audio:gen). Não vai pro browser.
# Pegue em elevenlabs.io > Settings > API Keys. Fica no .env.local (não comitado).
ELEVENLABS_API_KEY=
# Voz da narração. Vazio = default do script (Callum, nativa e rasgada).
# Atenção: no plano gratuito só vozes NATIVAS funcionam via API; as da
# biblioteca compartilhada devolvem 402 paid_plan_required.
ELEVENLABS_VOICE_ID=
# Modelo de narração: eleven_multilingual_v2 (default) ou eleven_v3.
# Só o v3 entende as tags de direção do audio/manifest.mjs.
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
# Estabilidade da voz 0–1. No v3 é discreta: 0 criativo, 0.5 natural, 1 robusto.
ELEVENLABS_VOICE_STABILITY=
# Modelo de música: music_v1 (mais barato/compatível) ou music_v2.
ELEVENLABS_MUSIC_MODEL=music_v1
